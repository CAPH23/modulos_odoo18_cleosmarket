<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <record id="ir_cron_goboxful_sync_status" model="ir.cron">
        <field name="name">Boxful: actualizar envíos abiertos</field>
        <field name="model_id" ref="stock.model_stock_picking"/>
        <field name="state">code</field>
        <field name="code">model._cron_goboxful_sync_status()</field>
        <field name="interval_number">15</field>
        <field name="interval_type">minutes</field>
        <field name="active">True</field>
    </record>
    <record id="ir_cron_goboxful_cleanup_logs" model="ir.cron">
        <field name="name">Boxful: limpiar logs técnicos</field>
        <field name="model_id" ref="stock.model_stock_picking"/>
        <field name="state">code</field>
        <field name="code">model._cron_goboxful_cleanup_logs()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active">True</field>
    </record>
</odoo>
