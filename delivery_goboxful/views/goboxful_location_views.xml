<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_goboxful_state_list" model="ir.ui.view">
        <field name="name">goboxful.state.list</field>
        <field name="model">goboxful.state</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="name"/>
                <field name="external_id"/>
                <field name="country_code"/>
                <field name="country_id" options="{'no_create': True, 'no_open': True}"/>
                <field name="last_sync_at"/>
                <field name="active"/>
            </list>
        </field>
    </record>
    <record id="view_goboxful_city_list" model="ir.ui.view">
        <field name="name">goboxful.city.list</field>
        <field name="model">goboxful.city</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="name"/>
                <field name="odoo_state_ids" string="Municipio" widget="many2many_tags"/>
                <field name="state_id" string="Departamento"/>
                <field name="external_id" string="External"/>
                <field name="active"/>
            </list>
        </field>
    </record>
    <record id="action_goboxful_states" model="ir.actions.act_window">
        <field name="name">Departamentos Boxful</field>
        <field name="res_model">goboxful.state</field>
        <field name="view_mode">list,form</field>
    </record>
    <record id="action_goboxful_cities" model="ir.actions.act_window">
        <field name="name">Ciudades Boxful</field>
        <field name="res_model">goboxful.city</field>
        <field name="view_mode">list,form</field>
    </record>
    <menuitem id="menu_goboxful_states" name="Departamentos" parent="menu_goboxful_root"
              action="action_goboxful_states" sequence="20"/>
    <menuitem id="menu_goboxful_cities" name="Ciudades y mapeos" parent="menu_goboxful_root"
              action="action_goboxful_cities" sequence="30"/>
</odoo>
