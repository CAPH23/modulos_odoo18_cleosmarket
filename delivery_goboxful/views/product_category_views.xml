<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="product_category_form_goboxful" model="ir.ui.view">
        <field name="name">product.category.form.goboxful</field>
        <field name="model">product.category</field>
        <field name="inherit_id" ref="product.product_category_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <group string="Boxful">
                    <field name="goboxful_block_shipping"/>
                    <field name="goboxful_effectively_blocked" readonly="1"/>
                    <div class="text-muted" colspan="2">
                        Al activar esta opción, Boxful se oculta completamente para productos de esta categoría
                        y de todas sus subcategorías.
                    </div>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
