<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="delivery_method_goboxful_details" inherit_id="website_sale.delivery_method">
        <xpath expr="//div[@t-if='dm.website_description']" position="before">
            <div t-if="dm.delivery_type == 'goboxful'"
                 class="o_goboxful_checkout_details d-none mt-2 small"
                 t-att-data-dm-id="dm.id"/>
        </xpath>
    </template>
</odoo>
