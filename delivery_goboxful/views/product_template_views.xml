<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="product_template_form_goboxful" model="ir.ui.view">
        <field name="name">product.template.form.goboxful</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Boxful" name="goboxful_shipping">
                    <group>
                        <group string="Dimensiones">
                            <field name="weight"/>
                            <field name="weight_uom_name" readonly="1"/>
                            <field name="volume"/>
                            <field name="volume_uom_name" readonly="1"/>
                            <field name="goboxful_width_cm"/>
                            <field name="goboxful_length_cm"/>
                            <field name="goboxful_height_cm"/>
                        </group>
                        <group string="Restricciones">
                            <field name="goboxful_is_fragile"/>
                            <field name="goboxful_shipping_blocked" readonly="1"/>
                            <field name="categ_id" readonly="1"/>
                        </group>
                    </group>
                    <div class="text-muted">
                        El peso se convierte desde la unidad configurada en Odoo hacia la unidad seleccionada
                        en la cuenta Boxful. El volumen se interpreta según product.volume_in_cubic_feet;
                        en esta instalación se encuentra configurado en metros cúbicos.
                    </div>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
