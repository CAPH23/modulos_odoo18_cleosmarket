<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <record id="payment_provider_cubopago" model="payment.provider">
        <field name="name">CuboPago</field>
        <field name="code">cubopago</field>
        <field name="state">disabled</field>
        <field name="company_id" ref="base.main_company"/>
        <field name="redirect_form_view_id" ref="payment_cubopago.redirect_form"/>
        <field name="cubopago_api_url_test">https://sandbox.api.cubopago.com</field>
        <field name="cubopago_api_url_prod">https://api.cubopago.com</field>
        <field name="cubopago_payment_description">Pedido {reference}</field>
        <field name="cubopago_send_client_info">True</field>
        <field name="cubopago_send_items">True</field>
        <field name="cubopago_max_items">20</field>
        <field name="cubopago_debug_logging">False</field>
    </record>
</odoo>
