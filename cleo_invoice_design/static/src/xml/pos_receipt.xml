<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
<t t-name="cleo_invoice_design.CleoPosOrderReceipt" t-inherit="point_of_sale.OrderReceipt" t-inherit-mode="extension" owl="1"><xpath expr="//div[hasclass('pos-receipt')]" position="replace"><div class="pos-receipt p-2 cleo-pos-receipt"><t t-set="data" t-value="props.data"/><t t-set="taxTotals" t-value="data.taxTotals"/><div class="cleo-pos-top-cut"></div><div class="cleo-pos-header"><img t-if="data.cleo_company_logo_url" class="cleo-pos-logo" t-att-src="data.cleo_company_logo_url"/><div class="cleo-pos-brand">SUPER TIENDA CLEO</div><div class="cleo-pos-contact-row"><span class="cleo-pos-icon">PIN</span> <span t-esc="data.cleo_company_address"/></div><div class="cleo-pos-contact-row"><span class="cleo-pos-icon">MAIL</span> <span t-esc="data.cleo_company_email"/></div><div class="cleo-pos-contact-row"><span class="cleo-pos-icon">TEL</span> <span t-esc="data.cleo_company_phone"/></div></div><div class="cleo-pos-dotted"></div><div class="cleo-pos-title-wrap"><div class="cleo-pos-title" t-esc="data.cleo_receipt_title"/><div class="cleo-pos-title-line"></div><div class="cleo-pos-badges"><span class="cleo-pos-badge cleo-pos-badge-green" t-esc="data.cleo_paid_label"/><span class="cleo-pos-badge cleo-pos-badge-yellow" t-esc="data.cleo_state_label"/></div></div><div class="cleo-pos-info-list"><div class="cleo-pos-info-row"><span class="cleo-pos-info-label">Referencia de pedido:</span><strong class="cleo-pos-info-value" t-esc="data.name"/></div><div class="cleo-pos-info-row"><span class="cleo-pos-info-label">Fecha y hora:</span><strong class="cleo-pos-info-value" t-esc="data.date"/></div><div class="cleo-pos-info-row"><span class="cleo-pos-info-label">Origen:</span><strong class="cleo-pos-info-value" t-esc="data.cleo_order_origin"/></div><div class="cleo-pos-info-row"><span class="cleo-pos-info-label">Metodo de pago:</span><strong class="cleo-pos-info-value"><t t-if="data.paymentlines &amp;&amp; data.paymentlines.length" t-esc="data.paymentlines[0].name"/><t t-else="">Pago registrado</t></strong></div></div><div class="cleo-pos-dotted"></div><table class="cleo-pos-items"><thead><tr><th class="cleo-pos-col-product">PRODUCTO</th><th class="cleo-pos-col-qty">CANT.</th><th class="cleo-pos-col-price">PRECIO</th><th class="cleo-pos-col-total">TOTAL</th></tr></thead><tbody><t t-if="data.orderlines &amp;&amp; data.orderlines.length" t-foreach="data.orderlines" t-as="line" t-key="line_index"><tr><td class="cleo-pos-item-product"><span class="cleo-pos-product-img-box"><img t-if="line.cleo_product_image_url" class="cleo-pos-product-img" t-att-src="line.cleo_product_image_url"/><span t-else="" class="cleo-pos-product-placeholder">*</span></span><span class="cleo-pos-product-name"><strong t-esc="line.cleo_product_name || line.productName"/></span></td><td class="cleo-pos-item-num" t-esc="line.qty"/><td class="cleo-pos-item-num" t-esc="line.unitPrice"/><td class="cleo-pos-item-num cleo-pos-line-total" t-esc="line.price"/></tr></t><tr t-if="!data.orderlines || !data.orderlines.length"><td colspan="4" class="cleo-pos-empty">Sin lineas de producto.</td></tr></tbody></table><div class="cleo-pos-dotted"></div><div class="cleo-pos-totals"><div class="cleo-pos-total-row"><span>Subtotal:</span><strong t-esc="props.formatCurrency(data.total_without_tax || 0)"/></div><div class="cleo-pos-total-row"><span>IVA incluido:</span><strong t-esc="props.formatCurrency(data.amount_tax || 0)"/></div><div class="cleo-pos-total-line"></div><div class="cleo-pos-total-row cleo-pos-grand-total"><span>TOTAL PAGADO:</span><strong t-esc="props.formatCurrency((taxTotals &amp;&amp; taxTotals.order_total) || data.amount_total || 0)"/></div><t t-if="data.paymentlines &amp;&amp; data.paymentlines.length"><div class="cleo-pos-payment-title">Pagos</div><t t-foreach="data.paymentlines" t-as="pay" t-key="pay_index"><div class="cleo-pos-total-row cleo-pos-payment-row"><span t-esc="pay.name"/><strong t-esc="props.formatCurrency(pay.amount || 0)"/></div></t></t><div t-if="data.show_change" class="cleo-pos-total-row"><span>Cambio:</span><strong t-esc="props.formatCurrency(data.order_change || 0)"/></div></div><div class="cleo-pos-dotted"></div><div class="cleo-pos-thanks">Gracias por tu compra</div><div class="cleo-pos-legal" t-esc="data.cleo_legal_note"/><div class="cleo-pos-footer" t-esc="data.cleo_social_footer"/><div class="after-footer"><t t-foreach="data.paymentlines" t-as="line" t-key="line_index"><t t-if="line.ticket"><div class="pos-payment-terminal-receipt pt-3"><pre t-esc="line.ticket"/></div></t></t></div></div></xpath></t>
</templates>
