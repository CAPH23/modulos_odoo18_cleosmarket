<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>

        <!--
            Quita "Powered by Odoo" del pie de los correos automáticos (confirmación
            de pedido, factura, etc.), conservando el enlace de "Dejar de seguir".

            mail.mail_notification_layout_with_responsible_signature es una vista
            "primary" que hereda de mail.mail_notification_layout, así que este
            inherit no-primary también la corrige a ella sin necesidad de tocarla
            aparte.
        -->
        <template id="remove_odoo_mail_layout_branding" inherit_id="mail.mail_notification_layout" name="Remove Odoo Mail Layout Branding">
            <xpath expr="//*[@id='mail_unfollow']/.." position="replace">
                <div t-if="show_footer" style="color: #555555; font-size:11px;">
                    <span id="mail_unfollow">
                        <a href="/mail/unfollow" style="text-decoration:none; color:#555555;">Dejar de seguir</a>
                    </span>
                </div>
            </xpath>
        </template>

        <template id="remove_odoo_mail_light_branding" inherit_id="mail.mail_notification_light" name="Remove Odoo Mail Light Branding">
            <xpath expr="//*[@id='mail_unfollow']/.." position="replace">
                <td align="center" style="min-width: 590px;">
                    <span id="mail_unfollow">
                        <a href="/mail/unfollow" style="text-decoration:none; color:#555555;">Dejar de seguir</a>
                    </span>
                </td>
            </xpath>
        </template>

    </data>
</odoo>
