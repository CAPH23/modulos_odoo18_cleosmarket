<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_picking_form_pedidosya" model="ir.ui.view">
        <field name="name">stock.picking.form.inherit.pedidosya</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="PedidosYa" name="pedidosya" invisible="not is_pedidosya">
                    <field name="is_pedidosya" invisible="1"/>
                    <group>
                        <group>
                            <field name="pedidosya_shipping_id" readonly="1"/>
                            <field name="pedidosya_confirmation_code" readonly="1"/>
                        </group>
                        <group>
                            <field name="pedidosya_status" readonly="1"/>
                            <field name="pedidosya_tracking_url" widget="url"
                                   readonly="1"/>
                        </group>
                    </group>
                    <div invisible="not pedidosya_shipping_id">
                        <button name="action_pedidosya_refresh_status" type="object"
                                string="Actualizar estado" class="btn-secondary"
                                icon="fa-refresh"/>
                        <button name="action_pedidosya_open_tracking" type="object"
                                string="Ver seguimiento" class="btn-secondary"
                                icon="fa-map-marker"
                                invisible="not pedidosya_tracking_url"/>
                    </div>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
