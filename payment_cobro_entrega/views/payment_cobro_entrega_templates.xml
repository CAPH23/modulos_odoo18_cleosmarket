<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="token_form" inherit_id="payment.token_form">
        <xpath expr="//t[@t-set='hide_secured_by']" position="attributes">
            <attribute name="t-value" separator=" " add="or provider_sudo.code == 'cleo_cod'"/>
        </xpath>
    </template>

    <template id="payment_method_form" inherit_id="payment.method_form">
        <xpath expr="//t[@t-set='hide_secured_by']" position="attributes">
            <attribute name="t-value" separator=" " add="or provider_sudo.code == 'cleo_cod'"/>
        </xpath>
    </template>

    <template id="redirect_form">
        <form t-att-action="api_url" method="post">
            <input type="hidden" name="reference" t-att-value="reference"/>
        </form>
    </template>

    <!--
        Message behavior for Cobro contra entrega:
        - While the related invoice is not paid, show one clear warning for the customer.
        - Hide Odoo's generic pending-payment alert for this provider to avoid duplicate messages.
        - When Odoo already shows the invoice as paid in the portal, show no pending-payment notice.
    -->
    <template id="cobro_entrega_state_header" inherit_id="payment.state_header">
        <xpath expr="//div[@name='o_payment_status_alert']" position="before">
            <div t-if="tx.provider_id.sudo().code == 'cleo_cod' and tx.state == 'pending' and not tx._cleo_cod_is_fully_paid()"
                 class="alert alert-warning mb-3"
                 role="alert">
                <h4 class="alert-heading mb-2">Pedido confirmado - pago pendiente contra entrega</h4>
                <p class="mb-2">
                    Tu pedido fue confirmado para preparación y envío. El pago sigue pendiente y
                    deberás pagarlo al transportista cuando recibas tus productos.
                </p>
                <p class="mb-0" t-if="tx._get_communication()">
                    <strong>Referencia del pedido:</strong>
                    <span t-out="tx._get_communication()"/>
                </p>
            </div>
        </xpath>

        <xpath expr="//div[@name='o_payment_status_alert']" position="attributes">
            <attribute name="t-if">not (tx.provider_id.sudo().code == 'cleo_cod' and tx.state == 'pending')</attribute>
        </xpath>
    </template>

</odoo>
